    function setupEventListeners() {
      document.getElementById('roleInstructor').addEventListener('click', () => selectRole('instructor'));
      document.getElementById('roleStudent').addEventListener('click', () => selectRole('student'));
      document.getElementById('loginBtn').addEventListener('click', handleLogin);
      document.getElementById('logoutBtn').addEventListener('click', handleLogout);
      
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => switchTab(btn.dataset.tab));
      });

      document.querySelectorAll('.step-action-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          openActivityModal(btn.dataset.step);
        });
      });

      document.querySelectorAll('.media-type-btn').forEach(btn => {
        btn.addEventListener('click', (e) => selectMediaType(e.target.closest('button').dataset.media));
      });

      document.getElementById('submitWorkshop').addEventListener('click', submitWorkshop);
      document.getElementById('startQuiz').addEventListener('click', startQuiz);
      document.getElementById('restartQuiz')?.addEventListener('click', restartQuiz);
      
      document.getElementById('workshopFile')?.addEventListener('change', handleFileSelect);
      document.getElementById('passwordInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleLogin();
      });
    }

    function selectRole(role) {
      currentRole = role;
      const instructorBtn = document.getElementById('roleInstructor');
      const studentBtn = document.getElementById('roleStudent');
      
      if (role === 'instructor') {
        instructorBtn.classList.add('border-orange-500', 'bg-orange-500/20', 'text-orange-400');
        instructorBtn.classList.remove('border-gray-500', 'bg-transparent', 'text-gray-400');
        studentBtn.classList.remove('border-teal-500', 'bg-teal-500/20', 'text-teal-400');
        studentBtn.classList.add('border-gray-500', 'bg-transparent', 'text-gray-400');
      } else {
        studentBtn.classList.add('border-teal-500', 'bg-teal-500/20', 'text-teal-400');
        studentBtn.classList.remove('border-gray-500', 'bg-transparent', 'text-gray-400');
        instructorBtn.classList.remove('border-orange-500', 'bg-orange-500/20', 'text-orange-400');
        instructorBtn.classList.add('border-gray-500', 'bg-transparent', 'text-gray-400');
      }
    }

    async function handleLogin() {
      const username = document.getElementById('usernameInput').value.trim();
      const password = document.getElementById('passwordInput').value.trim();
      const errorEl = document.getElementById('loginError');

      if (!username || !password) {
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      currentUser = username;

      if (window.dataSdk && allRecords.length < 999) {
        await window.dataSdk.create({
          id: Date.now().toString(),
          type: 'login',
          username: username,
          role: currentRole,
          activity: 'เข้าสู่ระบบ',
          score: 0,
          timestamp: new Date().toISOString(),
          content: '',
          file_type: '',
          file_name: '',
          file_size: '',
          media_type: ''
        });
      }

      document.getElementById('loginScreen').classList.add('hidden');
      document.getElementById('dashboard').classList.remove('hidden');
      document.getElementById('userDisplay').textContent = username;
      document.getElementById('roleDisplay').textContent = currentRole === 'instructor' ? '👨‍🏫 อาจารย์' : '👨‍🎓 นักศึกษา';

      // Show appropriate nav
      if (currentRole === 'instructor') {
        document.getElementById('studentNav').classList.add('hidden');
        document.getElementById('instructorNav').classList.remove('hidden');
        switchTab('dashboard');
      } else {
        document.getElementById('instructorNav').classList.add('hidden');
        document.getElementById('studentNav').classList.remove('hidden');
        switchTab('overview');
      }

      showToast('✅', `ยินดีต้อนรับ ${username}`);
    }

    function handleLogout() {
      currentUser = null;
      document.getElementById('dashboard').classList.add('hidden');
      document.getElementById('loginScreen').classList.remove('hidden');
      document.getElementById('usernameInput').value = '';
      document.getElementById('passwordInput').value = '';
      showToast('👋', 'ออกจากระบบแล้ว');
    }

    function switchTab(tab) {
      currentTab = tab;
      document.querySelectorAll('.tab-btn').forEach(btn => {
        if (btn.dataset.tab === tab) {
          btn.classList.add('bg-orange-500/20', 'text-orange-400', 'border-orange-500/50');
          btn.classList.remove('bg-white/5', 'text-gray-400', 'border-white/10');
        } else {
          btn.classList.remove('bg-orange-500/20', 'text-orange-400', 'border-orange-500/50');
          btn.classList.add('bg-white/5', 'text-gray-400', 'border-white/10');
        }
      });

      document.querySelectorAll('.tab-content').forEach(content => content.classList.add('hidden'));
      document.getElementById(`${tab}Tab`)?.classList.remove('hidden');
    }

    function selectMediaType(type) {
      currentMediaType = type;
      document.querySelectorAll('.media-type-btn').forEach(btn => {
        if (btn.dataset.media === type) {
          btn.classList.add('border-orange-500', 'bg-orange-500/20', 'text-orange-400');
          btn.classList.remove('border-gray-500', 'bg-transparent', 'text-gray-400');
        } else {
          btn.classList.remove('border-orange-500', 'bg-orange-500/20', 'text-orange-400');
          btn.classList.add('border-gray-500', 'bg-transparent', 'text-gray-400');
        }
      });
    }

    function handleFileSelect(e) {
      const file = e.target.files[0];
      if (!file) return;

      if (file.size > 50 * 1024 * 1024) {
        showToast('❌', 'ไฟล์ใหญ่เกินไป (สูงสุด 50MB)');
        return;
      }

      const reader = new FileReader();
      reader.onload = (event) => {
        currentFileData = {
          name: file.name,
          size: (file.size / 1024 / 1024).toFixed(2),
          type: file.type,
          data: event.target.result
        };

        document.getElementById('uploadText').textContent = `✅ ${file.name}`;
        document.getElementById('fileInfo').textContent = `ขนาด: ${currentFileData.size} MB`;
        document.getElementById('fileInfo').classList.remove('hidden');

        // Show preview for images/videos
        if (file.type.startsWith('image/')) {
          const img = document.createElement('img');
          img.src = event.target.result;
          img.className = 'w-full file-preview rounded-lg';
          document.getElementById('filePreview').innerHTML = '';
          document.getElementById('filePreview').appendChild(img);
          document.getElementById('filePreview').classList.remove('hidden');
        }
      };
      reader.readAsDataURL(file);
    }



    async function submitWorkshop() {
      if (!currentUser || !window.dataSdk) return;
      if (allRecords.length >= 999) {
        showToast('⚠️', 'ถึงขีดจำกัดการบันทึกแล้ว');
        return;
      }

      const name = document.getElementById('workshopName').value.trim();
      const title = document.getElementById('workshopTitle').value.trim();
      const contact = document.getElementById('workshopContact').value.trim();
      const bio = document.getElementById('workshopBio').value.trim();
      const eventName = document.getElementById('eventName').value.trim();
      const eventDate = document.getElementById('eventDate').value.trim();
      const eventLocation = document.getElementById('eventLocation').value.trim();
      const eventDesc = document.getElementById('eventDesc').value.trim();

      let content = '';
      let workshopType = '';
      let fileType = '';
      let fileName = '';
      let fileSize = '';

      if (name || title || contact || bio) {
        content = JSON.stringify({ type: 'business_card', name, title, contact, bio });
        workshopType = 'Digital Business Card';
      } else if (eventName || eventDate || eventLocation || eventDesc) {
        content = JSON.stringify({ type: 'event_poster', eventName, eventDate, eventLocation, eventDesc });
        workshopType = 'Event Poster';
      }

      if (!content) {
        showToast('⚠️', 'กรุณากรอกข้อมูลอย่างน้อย 1 รายการ');
        return;
      }

      if (currentFileData) {
        fileType = currentFileData.type;
        fileName = currentFileData.name;
        fileSize = currentFileData.size;
      }

      const result = await window.dataSdk.create({
        id: Date.now().toString(),
        type: 'workshop',
        username: currentUser,
        role: currentRole,
        activity: `ส่งผลงาน ${workshopType} (${currentMediaType})`,
        score: 0,
        timestamp: new Date().toISOString(),
        content: content,
        file_type: fileType,
        file_name: fileName,
        file_size: fileSize,
        media_type: currentMediaType
      });

      if (result.isOk) {
        showToast('🎨', 'ส่งผลงาน Workshop เรียบร้อย!');
        ['workshopName', 'workshopTitle', 'workshopContact', 'workshopBio', 'eventName', 'eventDate', 'eventLocation', 'eventDesc'].forEach(id => {
          document.getElementById(id).value = '';
        });
        document.getElementById('uploadText').textContent = '📤 คลิกเพื่อเลือกไฟล์ (สูงสุด 50MB)';
        document.getElementById('fileInfo').classList.add('hidden');
        document.getElementById('filePreview').classList.add('hidden');
        currentFileData = null;
      }
    }

    function startQuiz() {
      currentQuiz = 0;
      quizScore = 0;
      document.getElementById('startQuiz').classList.add('hidden');
      document.getElementById('quizResult').classList.add('hidden');
      document.getElementById('quizQuestion').classList.remove('hidden');
      renderQuestion();
    }

    function renderQuestion() {
      if (currentQuiz >= quizQuestions.length) {
        endQuiz();
        return;
      }

      const q = quizQuestions[currentQuiz];
      document.getElementById('questionNumber').textContent = `คำถามที่ ${currentQuiz + 1}/${quizQuestions.length}`;
      document.getElementById('questionText').textContent = q.q;
      
      quizTime = 30;
      document.getElementById('quizTimer').textContent = `⏱️ ${quizTime}s`;
      
      if (quizTimer) clearInterval(quizTimer);
      quizTimer = setInterval(() => {
        quizTime--;
        document.getElementById('quizTimer').textContent = `⏱️ ${quizTime}s`;
        if (quizTime <= 0) {
          clearInterval(quizTimer);
          nextQuestion();
        }
      }, 1000);

      const optionsHtml = q.options.map((opt, i) => `
        <button class="quiz-option w-full p-4 rounded-xl bg-white/5 border border-white/20 text-left text-white hover:bg-white/10 hover:border-purple-500 transition-all" data-index="${i}">
          <span class="inline-block w-8 h-8 rounded-full bg-purple-500/20 text-purple-400 text-center leading-8 mr-3 font-bold">${String.fromCharCode(65 + i)}</span>
          ${opt}
        </button>
      `).join('');
      
      document.getElementById('quizOptions').innerHTML = optionsHtml;
      
      document.querySelectorAll('.quiz-option').forEach(btn => {
        btn.addEventListener('click', () => selectAnswer(parseInt(btn.dataset.index)));
      });
    }

    function selectAnswer(index) {
      clearInterval(quizTimer);
      const q = quizQuestions[currentQuiz];
      
      document.querySelectorAll('.quiz-option').forEach((btn, i) => {
        btn.disabled = true;
        if (i === q.answer) {
          btn.classList.add('bg-green-500/30', 'border-green-500');
        } else if (i === index && index !== q.answer) {
          btn.classList.add('bg-red-500/30', 'border-red-500');
        }
      });

      if (index === q.answer) {
        quizScore++;
      }

      setTimeout(nextQuestion, 1500);
    }

    function nextQuestion() {
      currentQuiz++;
      renderQuestion();
    }

    async function endQuiz() {
      clearInterval(quizTimer);
      document.getElementById('quizQuestion').classList.add('hidden');
      document.getElementById('quizResult').classList.remove('hidden');
      document.getElementById('scoreText').textContent = `คะแนนของคุณ: ${quizScore}/${quizQuestions.length}`;

      if (currentUser && window.dataSdk && allRecords.length < 999) {
        await window.dataSdk.create({
          id: Date.now().toString(),
          type: 'quiz',
          username: currentUser,
          role: currentRole,
          activity: 'ทำ Quiz Game',
          score: quizScore,
          timestamp: new Date().toISOString(),
          content: '',
          file_type: '',
          file_name: '',
          file_size: '',
          media_type: ''
        });
      }
    }

    function restartQuiz() {
      document.getElementById('quizResult').classList.add('hidden');
      document.getElementById('startQuiz').classList.remove('hidden');
    }

    function updateAllStats() {
      const participants = new Set(allRecords.filter(r => r.type === 'login').map(r => r.username)).size;
      const activities = allRecords.filter(r => r.type === 'step').length;
      const workshops = allRecords.filter(r => r.type === 'workshop').length;
      const quizzes = allRecords.filter(r => r.type === 'quiz');
      const avgScore = quizzes.length > 0 ? Math.round(quizzes.reduce((sum, q) => sum + (q.score || 0), 0) / quizzes.length * 20) : 0;

      // Student stats
      const myActivities = allRecords.filter(r => r.type === 'step' && r.username === currentUser).length;
      const myWorkshops = allRecords.filter(r => r.type === 'workshop' && r.username === currentUser).length;
      const myQuizzes = allRecords.filter(r => r.type === 'quiz' && r.username === currentUser);
      const myScore = myQuizzes.length > 0 ? Math.round(myQuizzes[myQuizzes.length - 1].score / quizQuestions.length * 100) : 0;
      const myProgress = Math.min(100, Math.round((myActivities / 5) * 100));

      document.getElementById('statParticipants').textContent = participants;
      document.getElementById('statActivitiesIns').textContent = activities;
      document.getElementById('statSubmissions').textContent = workshops;
      document.getElementById('statAvgScore').textContent = avgScore + '%';

      document.getElementById('statProgress').textContent = myProgress + '%';
      document.getElementById('statActivities').textContent = myActivities;
      document.getElementById('statWorkshops').textContent = myWorkshops;
      document.getElementById('statScore').textContent = myScore + '%';
    }

    function renderStudentViews() {
      const myWorkshops = allRecords.filter(r => r.type === 'workshop' && r.username === currentUser).slice().reverse();
      const container = document.getElementById('myWorkshopGallery');

      if (myWorkshops.length === 0) {
        container.innerHTML = `
          <div class="p-4 rounded-xl bg-white/5 border border-white/10 text-center text-gray-400">
            <span class="text-4xl block mb-2">📭</span>
            <p class="text-sm">ยังไม่มีผลงาน</p>
          </div>
        `;
        return;
      }

      container.innerHTML = myWorkshops.map(w => {
        let data = {};
        try { data = JSON.parse(w.content); } catch (e) {}
        const isCard = data.type === 'business_card';
        const mediaIcon = { 'image/png': '📷', 'image/jpeg': '📷', 'video/mp4': '🎥', 'application/pdf': '📄' }[w.file_type] || '';
        
        return `
          <div class="p-4 rounded-xl ${isCard ? 'bg-gradient-to-br from-orange-500/10 to-red-500/10 border border-orange-500/30' : 'bg-gradient-to-br from-teal-500/10 to-blue-500/10 border border-teal-500/30'}">
            <div class="flex items-center justify-between mb-2">
              <span class="text-lg">${isCard ? '💼' : '📢'}</span>
              ${mediaIcon ? `<span class="text-lg">${mediaIcon}</span>` : ''}
            </div>
            <p class="text-white font-bold text-sm">${isCard ? (data.name || 'Business Card') : (data.eventName || 'Event Poster')}</p>
            <p class="text-gray-400 text-xs mt-1">${new Date(w.timestamp).toLocaleDateString('th-TH')}</p>
          </div>
        `;
      }).join('');
    }

    function renderInstructorViews() {
      // Recent Activities
      const recent = allRecords.slice().reverse().slice(0, 10);
      const activityContainer = document.getElementById('recentActivityLog');
      
      if (recent.length === 0) {
        activityContainer.innerHTML = '<div class="p-3 rounded-xl bg-white/5 border border-white/10 text-center text-gray-400"><p class="text-sm">ไม่มีกิจกรรม</p></div>';
      } else {
        activityContainer.innerHTML = recent.map(r => {
          const icon = r.type === 'login' ? '🔐' : r.type === 'step' ? '📚' : r.type === 'workshop' ? '🎨' : '🎮';
          return `
            <div class="flex items-center gap-2 p-3 rounded-xl bg-white/5 border border-white/10">
              <span class="text-lg">${icon}</span>
              <div class="flex-1 min-w-0">
                <p class="text-white text-sm font-medium truncate">${r.username}</p>
                <p class="text-gray-400 text-xs truncate">${r.activity}</p>
              </div>
              <span class="text-gray-500 text-xs whitespace-nowrap">${new Date(r.timestamp).toLocaleTimeString('th-TH')}</span>
            </div>
          `;
        }).join('');
      }

      // Student Monitoring
      const students = [...new Set(allRecords.filter(r => r.role === 'student').map(r => r.username))];
      const monitorContainer = document.getElementById('studentMonitoring');

      if (students.length === 0) {
        monitorContainer.innerHTML = '<div class="p-4 rounded-xl bg-white/5 border border-white/10"><p class="text-gray-400 text-sm">ยังไม่มีนักศึกษา</p></div>';
      } else {
        monitorContainer.innerHTML = students.map(student => {
          const studentActivities = allRecords.filter(r => r.username === student);
          const progress = Math.min(100, Math.round((studentActivities.filter(a => a.type === 'step').length / 5) * 100));
          return `
            <div class="p-4 rounded-xl bg-white/5 border border-white/10">
              <div class="flex items-center justify-between mb-2">
                <p class="text-white font-medium">${student}</p>
                <span class="px-2 py-1 rounded-full bg-purple-500/20 text-purple-400 text-xs">${progress}%</span>
              </div>
              <div class="w-full bg-white/10 rounded-full h-2">
                <div class="bg-gradient-to-r from-orange-500 to-purple-500 h-2 rounded-full" style="width: ${progress}%"></div>
              </div>
            </div>
          `;
        }).join('');
      }

      // Submitted Assignments
      const submissions = allRecords.filter(r => r.type === 'workshop');
      const submissionContainer = document.getElementById('submittedAssignments');

      if (submissions.length === 0) {
        submissionContainer.innerHTML = '<div class="p-4 rounded-xl bg-white/5 border border-white/10"><p class="text-gray-400 text-sm">ยังไม่มีงานที่ส่ง</p></div>';
      } else {
        submissionContainer.innerHTML = submissions.slice().reverse().slice(0, 10).map(s => {
          let data = {};
          try { data = JSON.parse(s.content); } catch (e) {}
          const mediaIcon = { 'image/png': '📷', 'image/jpeg': '📷', 'video/mp4': '🎥', 'application/pdf': '📄' }[s.file_type] || '📎';
          return `
            <div class="p-4 rounded-xl bg-white/5 border border-white/10">
              <div class="flex items-center justify-between mb-1">
                <p class="text-white font-medium">${s.username}</p>
                <span class="text-lg">${mediaIcon}</span>
              </div>
              <p class="text-gray-400 text-sm">${s.activity}</p>
              <p class="text-gray-500 text-xs mt-1">${new Date(s.timestamp).toLocaleString('th-TH')}</p>
            </div>
          `;
        }).join('');
      }
    }

    function showToast(icon, message) {
      const toast = document.getElementById('toast');
      document.getElementById('toastIcon').textContent = icon;
      document.getElementById('toastMessage').textContent = message;
      toast.classList.remove('translate-y-20', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      
      setTimeout(() => {
        toast.classList.add('translate-y-20', 'opacity-0');
        toast.classList.remove('translate-y-0', 'opacity-100');
      }, 3000);
    }

    function openActivityModal(step) {
      currentActivityStep = step;
      const activity = stepActivities[step];
      
      if (!activity) return;

      document.getElementById('modalTitle').textContent = activity.icon + ' ' + activity.title;
      document.getElementById('modalDuration').textContent = 'ระยะเวลา: ' + activity.duration;
      document.getElementById('modalContent').innerHTML = activity.content;
      document.getElementById('activityModal').classList.remove('hidden');
    }

    function closeActivityModal() {
      document.getElementById('activityModal').classList.add('hidden');
      currentActivityStep = null;
    }

    async function completeActivity() {
      if (!currentActivityStep || !currentUser || !window.dataSdk) return;
      if (allRecords.length >= 999) {
        showToast('⚠️', 'ถึงขีดจำกัดการบันทึกแล้ว');
        return;
      }

      const activity = stepActivities[currentActivityStep];
      const result = await window.dataSdk.create({
        id: Date.now().toString(),
        type: 'step',
        username: currentUser,
        role: currentRole,
        activity: `ขั้นที่ ${currentActivityStep}: ${activity.title}`,
        score: 0,
        timestamp: new Date().toISOString(),
        content: '',
        file_type: '',
        file_name: '',
        file_size: '',
        media_type: ''
      });

      if (result.isOk) {
        showToast('✅', `บันทึกกิจกรรมขั้นที่ ${currentActivityStep} แล้ว`);
        closeActivityModal();
      } else {
        showToast('❌', 'บันทึกไม่สำเร็จ');
      }
    }

    initApp();
